aws_region                = "eu-central-1"
project_name              = "golive2"
environment               = "dev"
vpc_cidr_block            = "10.40.0.0/16"
azs                       = ["eu-central-1a", "eu-central-1b"]
public_subnet_cidrs       = ["10.40.0.0/24", "10.40.1.0/24"]
private_app_subnet_cidrs  = ["10.40.10.0/24", "10.40.11.0/24"]
private_db_subnet_cidrs   = ["10.40.20.0/24", "10.40.21.0/24"]
allowed_ssh_cidrs         = ["203.0.113.10/32"]
cloudfront_aliases        = ["api-dev.example.com"]
cloudfront_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/replace-me"
jwt_issuer                = "https://idp.example.com/oauth2/default"
jwt_audience              = ["golive-api"]
jwks_uri                  = "https://idp.example.com/oauth2/default/v1/keys"
db_engine_version         = "15.00.4316.3.v1"
db_instance_class         = "db.m6i.large"
db_allocated_storage      = 100
db_max_allocated_storage  = 500
db_username               = "golive_admin"
ecs_instance_type         = "t3.large"
asg_min_size              = 2
asg_max_size              = 6
asg_desired_capacity      = 2
create_vpn                = false
customer_gateway_ip       = "198.51.100.10"
customer_gateway_bgp_asn  = 65000
vpn_static_routes         = ["172.16.0.0/16"]
service_images = {
  user_management   = "123456789012.dkr.ecr.eu-central-1.amazonaws.com/user-management:latest"
  device_management = "123456789012.dkr.ecr.eu-central-1.amazonaws.com/device-management:latest"
}
